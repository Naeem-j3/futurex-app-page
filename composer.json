{
    "name": "futurex/app-page",
    "description": "A Laravel package for app landing pages with analytics, screenshots, features, and Filament admin panel.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "filament",
        "landing page",
        "app page",
        "analytics",
        "package"
    ],
    "support": {
        "issues": "https://github.com/futurex/app-page/issues",
        "source": "https://github.com/futurex/app-page"
    },
    "autoload": {
        "psr-4": {
            "FutureX\\AppPage\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "FutureX\\AppPage\\AppPageServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.1",
        "filament/filament": "^3.0",
        "stevebauman/location": "^7.0"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
